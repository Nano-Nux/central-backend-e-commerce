  order            Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  uploadedBy       User?              @relation("UploadedPaymentProofs", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  reviewedBy       User?              @relation("ReviewedPaymentProofs", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([paymentId, createdAt])
  @@index([orderId, createdAt])
  @@index([status, createdAt])
  @@map("payment_proofs")
}

