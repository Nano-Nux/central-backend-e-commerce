model Payment {
  id                             String                        @id @default(uuid()) @db.Char(36)
  orderId                        String                        @map("order_id") @db.Char(36)
  method                         PaymentMethod
  amount                         Decimal                       @db.Decimal(15, 2)
  status                         PaymentStatus                 @default(PENDING)
  reference                      String?                       @unique @db.VarChar(255)
  idempotencyKey                 String?                       @unique @map("idempotency_key") @db.VarChar(255)
  refundOfPaymentId              String?                       @unique @map("refund_of_payment_id") @db.Char(36)
  merchantPaymentConfigurationId String?                       @map("merchant_payment_configuration_id") @db.Char(36)
  verificationContextJson        Json?                         @map("verification_context_json")
  createdAt                      DateTime                      @default(now()) @map("created_at")
  updatedAt                      DateTime                      @updatedAt @map("updated_at")
  order                          Order                         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  refundedPayment                Payment?                      @relation("PaymentRefundLink", fields: [refundOfPaymentId], references: [id], onDelete: SetNull)
  refunds                        Payment[]                     @relation("PaymentRefundLink")
  merchantPaymentConfiguration   MerchantPaymentConfiguration? @relation(fields: [merchantPaymentConfigurationId], references: [id], onDelete: SetNull)
  proofs                         PaymentProof[]
  providerSessions               PaymentProviderSession[]

  @@index([orderId])
  @@index([merchantPaymentConfigurationId])
  @@map("payments")
}

