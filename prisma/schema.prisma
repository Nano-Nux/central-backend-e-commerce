// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

enum UserStatus {
  ACTIVE   @map("active")
  INACTIVE @map("inactive")

  @@map("user_status")
}

enum ProductType {
  PHYSICAL
  DIGITAL
  SERVICE
  FOOD

  @@map("product_type")
}

enum PromotionDiscountType {
  FIXED
  PERCENTAGE

  @@map("promotion_discount_type")
}

enum AttributeValueType {
  TEXT
  NUMBER
  BOOLEAN
  SELECT
  DATE
  JSON

  @@map("attribute_value_type")
}

enum StockTrackingMode {
  SIMPLE
  BATCH
  ASSET

  @@map("stock_tracking_mode")
}

enum InventoryMovementType {
  IN
  OUT
  ADJUSTMENT
  RETURN

  @@map("inventory_movement_type")
}

enum InventoryReferenceType {
  ORDER
  PURCHASE
  ADJUSTMENT
  RETURN

  @@map("inventory_reference_type")
}

enum InventorySerialStatus {
  AVAILABLE
  SOLD
  RETURNED

  @@map("inventory_serial_status")
}

enum InventoryAssetStatus {
  AVAILABLE
  RESERVED
  SOLD
  RETURNED
  INACTIVE

  @@map("inventory_asset_status")
}

enum InventoryReservationStatus {
  ACTIVE
  RELEASED

  @@map("inventory_reservation_status")
}

enum BarcodeOwnerType {
  PRODUCT
  PRODUCT_VARIANT
  STOCK_ITEM
  STOCK_ITEM_UNIT
  INVENTORY_ASSET
  INVENTORY_BATCH

  @@map("barcode_owner_type")
}

enum InventoryTransformationType {
  PACK_BREAK
  REPACK
  ASSEMBLY
  ADJUSTMENT

  @@map("inventory_transformation_type")
}

enum InventoryTransformationLineDirection {
  IN
  OUT

  @@map("inventory_transformation_line_direction")
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
  COMPLETED

  @@map("order_status")
}

enum OrderSource {
  POS
  ONLINE

  @@map("order_source")
}

enum OrderType {
  CUSTOMER
  GUEST
  POS

  @@map("order_type")
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  ONLINE
  QR_MANUAL

  @@map("payment_method")
}

enum PaymentStatus {
  PENDING
  AWAITING_VERIFICATION
  SUCCESS
  FAILED

  @@map("payment_status")
}

enum MerchantPaymentProviderName {
  TH_PROMPTPAY
  MM_KBZPAY
  MM_WAVEPAY

  @@map("merchant_payment_provider_name")
}

enum PaymentProofStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("payment_proof_status")
}

enum PaymentProviderType {
  MANUAL_TRANSFER
  QR_TRANSFER
  LINE_PAY

  @@map("payment_provider_type")
}

enum PaymentProviderSessionStatus {
  PENDING
  CONFIRMED
  CANCELLED
  FAILED
  EXPIRED

  @@map("payment_provider_session_status")
}

enum POSSessionStatus {
  OPEN
  CLOSED

  @@map("pos_session_status")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE

  @@map("account_type")
}

enum JournalReferenceType {
  ORDER
  PURCHASE
  INVENTORY
  ADJUSTMENT
  PAYMENT

  @@map("journal_reference_type")
}

enum PurchaseOrderStatus {
  DRAFT
  APPROVED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED

  @@map("purchase_order_status")
}

enum SupplierInvoiceStatus {
  UNPAID
  PARTIAL
  PAID

  @@map("supplier_invoice_status")
}

enum CustomerType {
  RETAIL
  WHOLESALE

  @@map("customer_type")
}

enum CommunicationChannelType {
  EMAIL
  WEBSITE_CHAT
  LINE
  TELEGRAM
  DISCORD
  FACEBOOK_MESSENGER
  INSTAGRAM
  TIKTOK

  @@map("communication_channel_type")
}

enum ConversationStatus {
  OPEN
  CLOSED
  ARCHIVED

  @@map("conversation_status")
}

enum ConversationParticipantType {
  CUSTOMER
  USER
  BOT

  @@map("conversation_participant_type")
}

enum MessageDirection {
  INBOUND
  OUTBOUND

  @@map("message_direction")
}

enum WorkflowExecutionStatus {
  SUCCESS
  FAILED
  RUNNING

  @@map("workflow_execution_status")
}

enum OutboxEventStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED

  @@map("outbox_event_status")
}

enum InventoryReconciliationExceptionStatus {
  OPEN
  RESOLVED

  @@map("inventory_reconciliation_exception_status")
}

enum InventoryReconciliationExceptionType {
  MISSING_ORDER_STOCK_OUT
  MISSING_REFUND_RESTOCK
  PURCHASE_STOCK_IN_REPAIR_FAILED
  STALE_RESERVATION_RELEASE_FAILED

  @@map("inventory_reconciliation_exception_type")
}

enum AiProviderName {
  OPENAI
  GEMINI
  LOCAL
  OTHER

  @@map("ai_provider_name")
}

enum AiModuleSource {
  ORDER
  WORKFLOW
  CRM
  SYSTEM

  @@map("ai_module_source")
}

enum AiRequestStatus {
  SUCCESS
  FAILED

  @@map("ai_request_status")
}

model User {
  id                    String         @id @default(uuid()) @db.Char(36)
  name                  String         @db.VarChar(255)
  email                 String         @unique @db.VarChar(255)
  passwordHash          String         @map("password_hash") @db.VarChar(255)
  failedAttempts        Int            @default(0) @map("failed_attempts")
  lockedUntil           DateTime?      @map("locked_until")
  status                UserStatus     @default(ACTIVE)
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")
  roles                 UserRole[]
  refreshTokens         RefreshToken[]
  auditLogs             AuditLog[]
  posSessions           POSSession[]
  goodsReceipts         GoodsReceipt[]
  customers             Customer[]
  customerNotes         CustomerNote[]
  uploadedPaymentProofs PaymentProof[] @relation("UploadedPaymentProofs")
  reviewedPaymentProofs PaymentProof[] @relation("ReviewedPaymentProofs")

  @@index([lockedUntil])
  @@map("users")
}

model Role {
  id    String     @id @default(uuid()) @db.Char(36)
  name  String     @unique @db.VarChar(255)
  users UserRole[]

  @@map("roles")
}

model UserRole {
  userId String @map("user_id") @db.Char(36)
  roleId String @map("role_id") @db.Char(36)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Char(36)
  userId    String   @map("user_id") @db.Char(36)
  token     String   @unique @db.Char(64)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Char(36)
  actorId    String?  @map("actor_id") @db.Char(36)
  action     String   @db.VarChar(100)
  entityType String   @map("entity_type") @db.VarChar(100)
  entityId   String   @map("entity_id") @db.VarChar(255)
  before     Json?
  after      Json?
  metadata   Json?
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(512)
  createdAt  DateTime @default(now()) @map("created_at")
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model Category {
  id          String     @id @default(uuid()) @db.Char(36)
  name        String     @db.VarChar(255)
  label       String     @default("category") @db.VarChar(50)
  slug        String     @unique @db.VarChar(255)
  parentId    String?    @map("parent_id") @db.Char(36)
  description String?    @db.Text
  imageUrl    String?    @map("image_url") @db.VarChar(2048)
  path        String     @db.VarChar(768)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children    Category[] @relation("CategoryTree")
  productAssignments ProductCategory[]

  @@index([parentId])
  @@index([path])
  @@map("categories")
}

model Brand {
  id           String   @id @default(uuid()) @db.Char(36)
  name         String   @unique @db.VarChar(255)
  description  String?  @db.Text
  imageUrl     String   @map("image_url") @db.VarChar(2048)
  targetUrl    String?  @map("target_url") @db.VarChar(2048)
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([isActive, displayOrder])
  @@map("brands")
}

model BannerImage {
  id           String   @id @default(uuid()) @db.Char(36)
  imageUrl     String   @map("image_url") @db.VarChar(2048)
  targetUrl    String?  @map("target_url") @db.VarChar(2048)
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([isActive, displayOrder])
  @@map("banner_image_list")
}

model Voucher {
  id                 String                @id @default(uuid()) @db.Char(36)
  code               String                @unique @db.VarChar(100)
  description        String?               @db.Text
  discountType       PromotionDiscountType @map("discount_type")
  discountValue      Decimal               @map("discount_value") @db.Decimal(15, 2)
  minimumOrderAmount Decimal               @default(0) @map("minimum_order_amount") @db.Decimal(15, 2)
  startAt            DateTime?             @map("start_at")
  endAt              DateTime?             @map("end_at")
  usageLimit         Int?                  @map("usage_limit")
  usedCount          Int                   @default(0) @map("used_count")
  isActive           Boolean               @default(true) @map("is_active")
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")

  @@index([isActive, startAt, endAt])
  @@map("vouchers")
}

model Product {
  id                    String                       @id @default(uuid()) @db.Char(36)
  name                  String                       @db.VarChar(255)
  slug                  String                       @unique @db.VarChar(255)
  description           String?                      @db.Text
  shortDescription      String?                      @map("short_description") @db.VarChar(500)
  sku                   String?                      @unique @db.VarChar(100)
  barcode               String?                      @db.VarChar(100)
  type                  ProductType
  isActive              Boolean                      @default(true) @map("is_active")
  isFeatured            Boolean                      @default(false) @map("is_featured")
  isStockTracked        Boolean                      @default(true) @map("is_stock_tracked")
  isSerialized          Boolean                      @default(false) @map("is_serialized")
  publishedAt           DateTime?                    @map("published_at")
  createdAt             DateTime                     @default(now()) @map("created_at")
  updatedAt             DateTime                     @updatedAt @map("updated_at")
  categoryAssignments   ProductCategory[]
  variants              ProductVariant[]
  images                ProductImage[]
  attributes            ProductAttribute[]
  attributeAssignments  ProductAttributeAssignment[]
  prices                ProductPricing[]
  stockItems            StockItem[]
  barcodes              BarcodeRegistry[]
  inventoryItem         InventoryItem[]
  inventoryBatches      InventoryBatch[]
  inventoryMovements    InventoryMovement[]
  inventoryReservations InventoryReservation[]
  inventorySerials      InventorySerial[]
  orderItems            OrderItem[]
  purchaseOrderItems    PurchaseOrderItem[]
  goodsReceiptItems     GoodsReceiptItem[]
  cartItems             CartItem[]

  @@index([barcode])
  @@index([isFeatured, createdAt])
  @@index([publishedAt])
  @@map("products")
}

model ProductCategory {
  productId  String   @map("product_id") @db.Char(36)
  categoryId String   @map("category_id") @db.Char(36)
  createdAt  DateTime @default(now()) @map("created_at")
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
  @@map("product_categories")
}

model ProductVariant {
  id                   String                       @id @default(uuid()) @db.Char(36)
  productId            String                       @map("product_id") @db.Char(36)
  name                 String                       @db.VarChar(255)
  sku                  String                       @db.VarChar(100)
  barcode              String?                      @db.VarChar(100)
  attributes           Json
  isActive             Boolean                      @default(true) @map("is_active")
  deletedAt            DateTime?                    @map("deleted_at")
  createdAt            DateTime                     @default(now()) @map("created_at")
  updatedAt            DateTime                     @updatedAt @map("updated_at")
  product              Product                      @relation(fields: [productId], references: [id], onDelete: Cascade)
  prices               ProductPricing[]
  stockItems           StockItem[]
  attributeAssignments ProductAttributeAssignment[]
  barcodes             BarcodeRegistry[]
  orderItems           OrderItem[]
  cartItems            CartItem[]

  @@unique([id, productId])
  @@index([productId])
  @@index([sku])
  @@index([barcode])
  @@map("product_variants")
}

model ProductImage {
  id        String  @id @default(uuid()) @db.Char(36)
  productId String  @map("product_id") @db.Char(36)
  url       String  @db.VarChar(2048)
  position  Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model ProductAttribute {
  id        String  @id @default(uuid()) @db.Char(36)
  productId String  @map("product_id") @db.Char(36)
  key       String  @db.VarChar(100)
  value     String  @db.Text
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([key])
  @@map("product_attributes")
}

model ProductPricing {
  id               String          @id @default(uuid()) @db.Char(36)
  productId        String          @map("product_id") @db.Char(36)
  variantId        String?         @map("variant_id") @db.Char(36)
  costPrice        Decimal         @map("cost_price") @db.Decimal(15, 2)
  sellingPrice     Decimal         @map("selling_price") @db.Decimal(15, 2)
  wholesalePrice   Decimal?        @map("wholesale_price") @db.Decimal(15, 2)
  memberPrice      Decimal?        @map("member_price") @db.Decimal(15, 2)
  promotionPrice   Decimal?        @map("promotion_price") @db.Decimal(15, 2)
  promotionStartAt DateTime?       @map("promotion_start_at")
  promotionEndAt   DateTime?       @map("promotion_end_at")
  product          Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant          ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([variantId])
  @@map("product_prices")
}

model AttributeDefinition {
  id          String                       @id @default(uuid()) @db.Char(36)
  code        String                       @unique @db.VarChar(100)
  name        String                       @db.VarChar(255)
  description String?                      @db.Text
  valueType   AttributeValueType           @map("value_type")
  createdAt   DateTime                     @default(now()) @map("created_at")
  updatedAt   DateTime                     @updatedAt @map("updated_at")
  options     AttributeDefinitionOption[]
  assignments ProductAttributeAssignment[]

  @@index([name])
  @@map("attribute_definitions")
}

model AttributeDefinitionOption {
  id           String              @id @default(uuid()) @db.Char(36)
  definitionId String              @map("definition_id") @db.Char(36)
  value        String              @db.VarChar(255)
  label        String              @db.VarChar(255)
  position     Int                 @default(0)
  createdAt    DateTime            @default(now()) @map("created_at")
  definition   AttributeDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@unique([definitionId, value])
  @@index([definitionId, position])
  @@map("attribute_definition_options")
}

model ProductAttributeAssignment {
  id           String              @id @default(uuid()) @db.Char(36)
  definitionId String              @map("definition_id") @db.Char(36)
  productId    String              @map("product_id") @db.Char(36)
  variantId    String?             @map("variant_id") @db.Char(36)
  valueText    String?             @map("value_text") @db.Text
  valueNumber  Decimal?            @map("value_number") @db.Decimal(18, 6)
  valueBoolean Boolean?            @map("value_boolean")
  valueJson    Json?               @map("value_json")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")
  definition   AttributeDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  product      Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant      ProductVariant?     @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([definitionId])
  @@index([productId])
  @@index([variantId])
  @@map("product_attribute_assignments")
}

model MeasurementGroup {
  id        String           @id @default(uuid()) @db.Char(36)
  code      String           @unique @db.VarChar(100)
  name      String           @db.VarChar(255)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  units     UnitDefinition[]

  @@index([name])
  @@map("measurement_groups")
}

model UnitDefinition {
  id                  String                        @id @default(uuid()) @db.Char(36)
  code                String                        @unique @db.VarChar(100)
  name                String                        @db.VarChar(255)
  symbol              String?                       @db.VarChar(50)
  measurementGroupId  String?                       @map("measurement_group_id") @db.Char(36)
  allowsDecimal       Boolean                       @default(true) @map("allows_decimal")
  createdAt           DateTime                      @default(now()) @map("created_at")
  updatedAt           DateTime                      @updatedAt @map("updated_at")
  measurementGroup    MeasurementGroup?             @relation(fields: [measurementGroupId], references: [id], onDelete: SetNull)
  stockItemsAsBase    StockItem[]
  stockItemUnits      StockItemUnit[]
  conversionsFrom     StockItemUnitConversion[]     @relation("StockItemConversionFromUnit")
  conversionsTo       StockItemUnitConversion[]     @relation("StockItemConversionToUnit")
  movementUnits       InventoryMovement[]
  reservationUnits    InventoryReservation[]
  orderItems          OrderItem[]
  cartItems           CartItem[]
  purchaseOrderItems  PurchaseOrderItem[]
  goodsReceiptItems   GoodsReceiptItem[]
  transformationLines InventoryTransformationLine[]

  @@index([measurementGroupId])
  @@index([name])
  @@map("unit_definitions")
}

model StockItem {
  id                    String                        @id @default(uuid()) @db.Char(36)
  productId             String                        @map("product_id") @db.Char(36)
  variantId             String?                       @map("variant_id") @db.Char(36)
  name                  String                        @db.VarChar(255)
  sku                   String                        @db.VarChar(100)
  isActive              Boolean                       @default(true) @map("is_active")
  trackInventory        Boolean                       @default(true) @map("track_inventory")
  trackingMode          StockTrackingMode             @default(SIMPLE) @map("tracking_mode")
  baseUnitId            String?                       @map("base_unit_id") @db.Char(36)
  createdAt             DateTime                      @default(now()) @map("created_at")
  updatedAt             DateTime                      @updatedAt @map("updated_at")
  product               Product                       @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant               ProductVariant?               @relation(fields: [variantId, productId], references: [id, productId], onDelete: Cascade)
  baseUnit              UnitDefinition?               @relation(fields: [baseUnitId], references: [id], onDelete: SetNull)
  units                 StockItemUnit[]
  conversions           StockItemUnitConversion[]
  inventoryItem         InventoryItem?
  inventoryBatches      InventoryBatch[]
  inventoryMovements    InventoryMovement[]
  inventoryReservations InventoryReservation[]
  inventorySerials      InventorySerial[]
  orderItems            OrderItem[]
  cartItems             CartItem[]
  purchaseOrderItems    PurchaseOrderItem[]
  goodsReceiptItems     GoodsReceiptItem[]
  configuration         StockItemConfiguration?
  identifierRules       StockItemIdentifierRule[]
  assets                InventoryAsset[]
  barcodes              BarcodeRegistry[]
  transformationLines   InventoryTransformationLine[]

  @@unique([productId, variantId])
  @@index([productId])
  @@index([variantId])
  @@index([baseUnitId])
  @@map("stock_items")
}

model StockItemConfiguration {
  stockItemId           String    @id @map("stock_item_id") @db.Char(36)
  trackBatches          Boolean   @default(false) @map("track_batches")
  trackExpiry           Boolean   @default(false) @map("track_expiry")
  trackUniqueAssets     Boolean   @default(false) @map("track_unique_assets")
  trackReservations     Boolean   @default(true) @map("track_reservations")
  allowUnitConversions  Boolean   @default(false) @map("allow_unit_conversions")
  allowPackBreaking     Boolean   @default(false) @map("allow_pack_breaking")
  allowMultipleBarcodes Boolean   @default(false) @map("allow_multiple_barcodes")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  stockItem             StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@map("stock_item_configurations")
}

model StockItemIdentifierRule {
  id               String                  @id @default(uuid()) @db.Char(36)
  stockItemId      String                  @map("stock_item_id") @db.Char(36)
  identifierTypeId String                  @map("identifier_type_id") @db.Char(36)
  isRequired       Boolean                 @default(true) @map("is_required")
  minCount         Int                     @default(1) @map("min_count")
  maxCount         Int?                    @map("max_count")
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")
  stockItem        StockItem               @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  identifierType   InventoryIdentifierType @relation(fields: [identifierTypeId], references: [id], onDelete: Restrict)

  @@unique([stockItemId, identifierTypeId])
  @@index([identifierTypeId])
  @@map("stock_item_identifier_rules")
}

model StockItemUnit {
  id               String            @id @default(uuid()) @db.Char(36)
  stockItemId      String            @map("stock_item_id") @db.Char(36)
  unitId           String            @map("unit_id") @db.Char(36)
  conversionToBase Decimal           @map("conversion_to_base") @db.Decimal(20, 8)
  isBaseUnit       Boolean           @default(false) @map("is_base_unit")
  isSalesUnit      Boolean           @default(false) @map("is_sales_unit")
  isPurchaseUnit   Boolean           @default(false) @map("is_purchase_unit")
  allowsFractional Boolean           @default(true) @map("allows_fractional")
  position         Int               @default(0)
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  stockItem        StockItem         @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  unit             UnitDefinition    @relation(fields: [unitId], references: [id], onDelete: Restrict)
  barcodes         BarcodeRegistry[]

  @@unique([stockItemId, unitId])
  @@index([unitId])
  @@index([stockItemId, position])
  @@map("stock_item_units")
}

model StockItemUnitConversion {
  id          String         @id @default(uuid()) @db.Char(36)
  stockItemId String         @map("stock_item_id") @db.Char(36)
  fromUnitId  String         @map("from_unit_id") @db.Char(36)
  toUnitId    String         @map("to_unit_id") @db.Char(36)
  factor      Decimal        @db.Decimal(20, 8)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  stockItem   StockItem      @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
