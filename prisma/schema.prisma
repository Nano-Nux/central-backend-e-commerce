model PaymentProof {
  id               String             @id @default(uuid()) @db.Char(36)
  paymentId        String             @map("payment_id") @db.Char(36)
  orderId          String             @map("order_id") @db.Char(36)
  bucket           String             @db.VarChar(255)
  objectName       String             @map("object_name") @db.VarChar(512)
  originalFilename String             @map("original_filename") @db.VarChar(255)
  contentType      String             @map("content_type") @db.VarChar(255)
  size             Int
  status           PaymentProofStatus @default(PENDING)
  rejectionReason  String?            @map("rejection_reason") @db.VarChar(500)
  uploadedByUserId String?            @map("uploaded_by_user_id") @db.Char(36)
  reviewedByUserId String?            @map("reviewed_by_user_id") @db.Char(36)
  reviewedAt       DateTime?          @map("reviewed_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
