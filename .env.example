# APP
APP_PORT=3001
NODE_ENV=development
APP_BASE_URL=http://localhost:3001/api/v1
APP_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# DATABASE
DATABASE_URL="mysql://user:password@localhost:3306/central_backend"
# Enable only when your MySQL/MariaDB server uses caching_sha2_password or
# sha256_password and the client cannot provide an RSA public key directly.
DATABASE_ALLOW_PUBLIC_KEY_RETRIEVAL=false

# AUTH
JWT_SECRET="change-me"
JWT_EXPIRES_IN="1d"
REFRESH_SECRET="change-me-refresh"
REFRESH_EXPIRES_IN="30d"

# ADMIN BOOTSTRAP
# Used on app startup to create or grant the Admin role to this account.
ADMIN_USERNAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@12345

# GOOGLE OAUTH
# Reserved for customer social login. Leave empty until OAuth is enabled.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# CURRENCY
APP_CURRENCY=THB
CURRENCY_SYMBOL=THB

# MINIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=business-files
MINIO_PAYMENT_PROOF_BUCKET=payment-proofs
MINIO_PAYMENT_QR_BUCKET=payment-qr

# LINE PAY
LINE_PAY_CHANNEL_ID=
LINE_PAY_CHANNEL_SECRET=

# TELEGRAM
# Bot token from @BotFather and chat ID to receive order notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# CHANNEL WEBHOOK SECURITY
# HMAC/token secrets used by POST /api/v1/webhooks/*.
WEBHOOK_LINE_SECRET=
WEBHOOK_TELEGRAM_SECRET=
WEBHOOK_DISCORD_SECRET=
WEBHOOK_FACEBOOK_SECRET=
WEBHOOK_INSTAGRAM_SECRET=
WEBHOOK_TIKTOK_SECRET=
